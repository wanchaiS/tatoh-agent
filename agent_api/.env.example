OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://ai-gateway.vercel.sh/v1
MODEL_NAME=openai/gpt-4o-mini
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=project_name

# PMS Configuration
PMS_BASE_URL=api
PMS_HOTEL_CODE=code
PMS_USERNAME=username
PMS_PASSWORD=password
PMS_ACCESS_TOKEN=token


# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5431/postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres


# API Server
HOST=0.0.0.0
PORT=8000

# Auth
# Generate secret: openssl rand -hex 32
JWT_SECRET=your_64_char_hex_secret
JWT_EXPIRE_MINUTES=10

# Admin users — one var per user, value is bcrypt hash
# Generate hash: uv run python -c "import bcrypt; print(bcrypt.hashpw(b'yourpass', bcrypt.gensalt()).decode())"
# ADMIN_USER_ALICE=$2b$12$...
# ADMIN_USER_BOB=$2b$12$...